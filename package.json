{
  "name": "abapgit-agent",
  "version": "1.7.2",
  "description": "ABAP Git Agent - Pull and activate ABAP code via abapGit from any git repository",
  "main": "src/index.js",
  "files": [
    "bin/",
    "src/",
    "abap/guidelines/",
    "abap/CLAUDE.md",
    "abap/.github/copilot-instructions.md",
    ".abapGitAgent.example"
  ],
  "bin": {
    "abapgit-agent": "bin/abapgit-agent",
    "abgagt": "bin/abgagt"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest",
    "test:all": "node scripts/test-all.js",
    "test:jest": "jest",
    "test:aunit": "node scripts/test-all.js --aunit",
    "test:cmd": "node scripts/test-all.js --cmd",
    "test:cmd:demo": "node scripts/test-all.js --cmd --demo",
    "pull": "node bin/abapgit-agent",
    "release": "node scripts/release.js",
    "unrelease": "node scripts/unrelease.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "node-fetch": "^2.7.0",
    "uuid": "^9.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "supertest": "^7.2.2"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
