{
  "project": {
    "name": "abapgit-agent",
    "description": "CLI tool for pulling and activating ABAP objects from git repositories"
  },

  "safeguards": {
    "requireFilesForPull": false,
    "disablePull": false,
    "disableRun": false,
    "disableImport": false,
    "importAllowedUsers": null,
    "requireImportMessage": false,
    "disableProbeClasses": false,
    "reason": null
  },

  "conflictDetection": {
    "mode": "abort",
    "reason": null
  }
}
