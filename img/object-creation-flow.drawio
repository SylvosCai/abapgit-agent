                            <mxPoint x="1100" y="560"/>
                            <mxPoint x="1100" y="625"/>
                        </Array>
                    </mxGeometry>
                </mxCell>

                <!-- sap_zname → sap_ask  (PoC/probe loop down) -->
                <mxCell id="e27" value="PoC / probe" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="sap_zname" target="sap_ask" parent="1">
                    <mxGeometry relative="1" as="geometry">
