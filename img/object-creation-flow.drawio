                <!-- sap_ask → probe_ns  (Probe, far right) -->
                <mxCell id="e8" value="Probe" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="sap_ask" target="probe_ns" parent="1">
                    <mxGeometry relative="1" as="geometry">
                        <Array as="points">
                            <mxPoint x="2230" y="625"/>
                            <mxPoint x="2230" y="790"/>
                        </Array>
