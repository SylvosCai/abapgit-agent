                </mxCell>

                <!-- sap_ask → sap_pkg  (Production, left) -->
                <mxCell id="e6" value="Production" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="sap_ask" target="sap_pkg" parent="1">
                    <mxGeometry relative="1" as="geometry">
