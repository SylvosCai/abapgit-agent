                </mxCell>

                <!-- sap_summary → sap_confirmed -->
                <mxCell id="e10" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="sap_summary" target="sap_confirmed" parent="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>

                <!-- sap_confirmed → sap_write  (Yes) -->
                <mxCell id="e11" value="Yes" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="sap_confirmed" target="sap_write" parent="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>

                <!-- sap_confirmed → sap_summary  (No, loop back) -->
